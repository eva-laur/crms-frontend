PORT=5000

# MongoDB connection string (Atlas or local). NEVER commit a real one.
MONGO_URI=mongodb+srv://<user>:<password>@<cluster-url>/crms?retryWrites=true&w=majority

# Use a long random string in any real deployment, e.g.
# `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`
JWT_SECRET=replace_me_with_a_long_random_string

# Comma-separated list of allowed frontend origins for CORS.
# Defaults to http://localhost:5173,http://localhost:3000 if unset.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional — files (course materials, assignment submissions, fuel-log
# receipts) are stored locally on disk under server/uploads/ and served back
# out from this API. Only set this if the API is reachable at a different
# public origin than http://localhost:<PORT> (e.g. in production).
SERVER_PUBLIC_URL=http://localhost:5000

# Optional — only needed for email notifications.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM="Campus MRS <your-email@gmail.com>"
